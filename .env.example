# YApi MCP Server Configuration
# Copy this template to a separate file and fill in your actual values.
# This file is NOT auto-loaded; set YAPI_ENV_FILE to your chosen file path.

# YApi server base URL (without trailing slash)
YAPI_SERVER_URL=https://your-yapi-instance.com

# YApi authentication cookies (obtain from browser after login)
# Open browser DevTools → Application/Storage → Cookies → your YApi domain
YAPI_TOKEN=your_yapi_token_value
YAPI_UID=your_yapi_uid_value

# Optional: Additional CAS authentication cookie (only needed for custom deployments)
# YAPI_CAS=your_yapi_cas_value
